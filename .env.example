# Backend local (SQLite)
PAF_ADMIN_USER=admin
PAF_ADMIN_PASSWORD=defina-uma-senha-forte
PORT=5180
PAF_DB_PATH=data/paf.sqlite

# Em produção, SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetadas
# automaticamente no Edge Function. Nunca exponha a service role no Vite.
# Para executar uma única vez `npm run bootstrap:admin`, defina localmente:
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# PAF_BOOTSTRAP_ADMIN_NAME=Administrador PAF
# PAF_BOOTSTRAP_ADMIN_LOGIN=ADMIN
# PAF_BOOTSTRAP_ADMIN_PASSWORD=
